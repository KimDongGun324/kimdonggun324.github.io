## 4. 완성된 코드

```cpp
#include <iostream>

using namespace std;

// ① 값 전달 - 원본은 안 바뀜
int MySwapValue(int i, int j)
{
    int temp = i;
    i = j;
    j = temp;
    return temp;
}

// ② 포인터 전달 - 원본이 바뀜
void MySwapPtr(int* i, int* j)
{
    int temp = *i;
    *i = *j;
    *j = temp;
}

// ③ 참조 전달 - 원본이 바뀜 (가장 깔끔)
void MySwapRef(int& i, int& j)
{
    int temp = i;
    i = j;
    j = temp;
}

// 오름차순 정렬 확인
bool CheckSorted(int a, int b)
{
    return a <= b;  // a가 b 이하면 정렬된 상태
}

int main()
{
    // Swap 테스트
    {
        int a = 3;
        int b = 2;

        cout << a << " " << b << endl;    // 출력: 3 2

        MySwapRef(a, b);                  // 교환!

        cout << a << " " << b << endl;    // 출력: 2 3
    }

    // 정렬(sorting) - 두 원소
    {
        int arr[] = { 9, 3 };

        cout << arr[0] << " " << arr[1] << endl;   // 출력: 9 3

        if (arr[0] > arr[1])
        {
            MySwapRef(arr[0], arr[1]);   // 앞이 크면 교환
        }

        cout << arr[0] << " " << arr[1] << endl;   // 출력: 3 9
    }

    // 어떤 값이 들어와도 항상 작은 값이 먼저 출력
    {
        int arr[2];

        cout << "두 정수를 입력하세요: ";
        cin >> arr[0] >> arr[1];

        if (!CheckSorted(arr[0], arr[1]))   // 정렬 안 되어 있으면?
        {
            MySwapRef(arr[0], arr[1]);       // 교환!
        }

        cout << arr[0] << " " << arr[1] << endl;  // 항상 작은 값 먼저!
    }

    return 0;
}
```

